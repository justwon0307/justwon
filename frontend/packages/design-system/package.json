{
  "name": "@justwon/designs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./brand": {
      "types": "./dist/brand/index.d.ts",
      "import": "./dist/brand/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./globals.css": {
      "types": "./dist/globals.css.d.ts",
      "default": "./dist/globals.css.js"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "icons": "svg2tsx generate && prettier --write ./src/icons",
    "dev": "tsc --watch --project tsconfig.build.json",
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules"
  },
  "devDependencies": {
    "@justkits/svg2tsx": "catalog:",
    "@justwon/tsconfig": "workspace:*",
    "@justwon/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "catalog:",
    "@vanilla-extract/dynamic": "catalog:",
    "@vanilla-extract/recipes": "catalog:",
    "clsx": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --check",
    "*.{ts,tsx,js,jsx}": [
      "eslint",
      "prettier --check"
    ]
  }
}
