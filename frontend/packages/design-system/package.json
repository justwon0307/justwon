{
  "name": "@justwon/designs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./brand": {
      "types": "./dist/brand.d.mts",
      "import": "./dist/brand.mjs"
    },
    "./components": {
      "types": "./dist/components.d.mts",
      "import": "./dist/components.mjs"
    },
    "./icons": {
      "types": "./dist/icons.d.mts",
      "import": "./dist/icons.mjs"
    },
    "./theme": {
      "types": "./dist/theme.d.mts",
      "import": "./dist/theme.mjs"
    },
    "./globals.css": {
      "types": "./dist/globals.d.mts",
      "default": "./dist/globals.mjs"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "icons": "svg2tsx generate && prettier --write ./src/icons",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules"
  },
  "devDependencies": {
    "@justkits/svg2tsx": "catalog:",
    "@justwon/vitest-config": "workspace:*"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "catalog:",
    "@vanilla-extract/dynamic": "catalog:",
    "@vanilla-extract/recipes": "catalog:",
    "clsx": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --check",
    "*.{ts,tsx,js,jsx}": [
      "eslint",
      "prettier --check"
    ]
  }
}
